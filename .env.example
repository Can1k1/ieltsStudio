# IELTS Studio — Environment Variables
# Copy this file to .env and fill in your values.
# .env is .gitignored — never commit real keys.

# OpenAI API key — used for AI-powered essay feedback
# Get yours at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# Optional: override the OpenAI model (default: gpt-4o-mini)
# OPENAI_MODEL=gpt-4o

# Optional: max retries on API failure (default: 3)
# AI_MAX_RETRIES=3

# Optional: disable AI fallback to local evaluator (default: true)
# AI_FALLBACK_ENABLED=true
